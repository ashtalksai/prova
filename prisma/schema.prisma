datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  company       String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  vehicles       Vehicle[]
  owners         Owner[]
  scheduleEvents ScheduleEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Owner {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]

  @@index([userId])
}

model Vehicle {
  id        String   @id @default(cuid())
  make      String
  model     String
  year      Int
  vin       String   @unique
  color     String?
  imageUrl  String?
  bay       String?
  status    String   @default("stored")
  notes     String?
  ownerId   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner          Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  climateLogs    ClimateLog[]
  serviceRecords ServiceRecord[]
  scheduleEvents ScheduleEvent[]

  @@index([ownerId])
  @@index([userId])
  @@index([status])
}

model ClimateLog {
  id          String   @id @default(cuid())
  vehicleId   String
  temperature Float
  humidity    Float
  recordedAt  DateTime @default(now())
  notes       String?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([recordedAt])
}

model ServiceRecord {
  id          String   @id @default(cuid())
  vehicleId   String
  type        String
  description String
  provider    String?
  cost        Float?
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([date])
}

model ScheduleEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  vehicleId   String?
  date        DateTime
  type        String    @default("maintenance")
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([userId])
  @@index([date])
}
